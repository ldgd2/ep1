# ─── Base de Datos ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/emergencias_vehiculares

# ─── JWT ──────────────────────────────────────────────────────────
SECRET_KEY=cambia_esto_por_una_clave_secreta_muy_larga_y_segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── App ──────────────────────────────────────────────────────────
APP_NAME="Plataforma Inteligente de Atención de Emergencias Vehiculares"
DEBUG=True
API_V1_PREFIX=/api/v1

# ─── IA (OpenRouter) ──────────────────────────────────────────────
OPENROUTER_API_KEY=tu_api_key_de_openrouter
OPENROUTER_MODEL_NAME=meta-llama/llama-3-8b-instruct

# ─── Transcripción (Whisper Local) ────────────────────────────────
WHISPER_MODEL_SIZE=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8


